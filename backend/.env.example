# Ratefluencer Backend Configuration
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Data Files
CREATORS_CSV=synthetic_influencer_v2.csv

# Model Configuration
MODEL_VERSION=v2
LOG_LEVEL=INFO
