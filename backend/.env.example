# Ratefluencer Backend Configuration
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Data Files
CREATORS_CSV=influencers_engine_ready.csv

# Model Configuration
MODEL_VERSION=v2
LOG_LEVEL=INFO

# Groq API Key — REQUIRED for content generation, AI agent, storyboard
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API v3 — optional, enables real YouTube trend data
# Get free key at: https://console.cloud.google.com (10,000 units/day free)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ElevenLabs — optional, enables high-quality voiceover in Reel Assets
# Get free key at: https://elevenlabs.io (10,000 chars/month free)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
